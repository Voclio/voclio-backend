{
  "name": "voclio-api",
  "version": "1.0.0",
  "description": "Voclio System API - Voice Notes and Task Management",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "worker": "node workers/queue.worker.js",
    "worker:dev": "nodemon workers/queue.worker.js",
    "init-db": "node scripts/initDatabase.js",
    "test-db": "node test-connection.js",
    "migrate:storage": "node scripts/migrate-to-cloud.js",
    "migrate:storage:dry": "node scripts/migrate-to-cloud.js --dry-run",
    "migrate:notifications": "node database/migrations/run_notification_fix.js",
    "migrate:google-calendar": "node database/migrations/run_google_calendar_sync.js",
    "migrate:webex": "node database/migrations/run_add_webex_sync.js",
    "migrate:enums": "node fix-all-enums.js",
    "fix:enums": "node fix-all-enums.js",
    "fix:timestamps": "node fix-all-timestamps.js",
    "check:enums": "node check-enum-status.js",
    "check:categories": "node check-categories.js",
    "verify:all": "node verify-all-fixes.js",
    "postman": "node generate-postman-collection.js",
    "docs": "echo Available docs: ALL_APIS_COMPLETE.md, POSTMAN_GUIDE.md, API_COMPLETE_REFERENCE.md",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --coverage",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/jest --watch",
    "test:unit": "node --experimental-vm-modules node_modules/.bin/jest tests/unit",
    "test:integration": "node --experimental-vm-modules node_modules/.bin/jest tests/integration",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/jest --coverage --coverageDirectory=coverage",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\"",
    "docker:build": "docker build -t voclio-api .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "keywords": [
    "voice",
    "notes",
    "tasks",
    "productivity"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.515.0",
    "@aws-sdk/s3-request-presigner": "^3.515.0",
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.13.4",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.1.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "google-auth-library": "^10.5.0",
    "googleapis": "^171.0.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "pg": "^8.18.0",
    "pg-hstore": "^2.3.4",
    "resend": "^6.9.1",
    "sequelize": "^6.37.7",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/supertest": "^6.0.2",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "supertest": "^6.3.4"
  }
}
